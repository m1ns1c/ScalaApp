<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0D1B2A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="멀티 모드"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvMyIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="내 IP: 확인 중..."
        android:textSize="13sp"
        android:textColor="#7B9EC7"
        android:layout_marginBottom="40dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A2E45"
        android:padding="24dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏠  방장으로 시작"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 IP를 친구에게 알려주세요"
            android:textSize="12sp"
            android:textColor="#7B9EC7"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="방 만들기"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#1B3A6B"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A2E45"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚪  방 입장하기"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="방장의 IP를 입력하세요"
            android:textSize="12sp"
            android:textColor="#7B9EC7"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etRoomIp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="예: 192.168.0.5"
            android:textColor="#FFFFFF"
            android:textColorHint="#4A6080"
            android:background="#0D1B2A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnJoin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="입장하기"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#0E4D3A"/>

    </LinearLayout>

</LinearLayout>