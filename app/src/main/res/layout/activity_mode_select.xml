<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="32dp"
        android:minHeight="500dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=" "
            android:padding="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="게임 모드"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="함께 즐길 방식을 선택하세요"
            android:textSize="13sp"
            android:textColor="#7B9EC7"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2E45"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖  AI 모드"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI 스칼라와 1:1 게임 연습"
                android:textSize="12sp"
                android:textColor="#7B9EC7"/>

            <Button
                android:id="@+id/btnAiMode"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="시작하기"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#1B3A6B"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2E45"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥  멀티 모드"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="같은 와이파이로 친구들과 대결"
                android:textSize="12sp"
                android:textColor="#7B9EC7"/>

            <Button
                android:id="@+id/btnMultiMode"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="시작하기"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#0E4D3A"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>