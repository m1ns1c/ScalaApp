<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ScalaApp" parent="Theme.AppCompat.DayNight">
        <item name="colorPrimary">@color/dark_blue</item>
        <item name="colorPrimaryDark">@color/dark_bg</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="actionBarStyle">@style/DarkActionBar</item>
    </style>

    <style name="Theme.ScalaApp" parent="Base.Theme.ScalaApp" />

    <style name="DarkActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/dark_bg</item>
        <item name="titleTextStyle">@style/DarkActionBarTitle</item>
        <item name="android:textColorSecondary">#FFFFFF</item>
    </style>

    <style name="DarkActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">18sp</item>
    </style>
</resources>